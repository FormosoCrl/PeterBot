# ==========================================
# 🧠 APIs
# ==========================================
GEMINI_API_KEY=your_gemini_api_key_here
HF_TOKEN=your_huggingface_token_here

# Modelo Gemini (opcional, default gemini-3-flash-preview)
# GEMINI_MODEL=gemini-3-flash-preview

# ==========================================
# ⚙️ Comportamiento del orquestador
# ==========================================
# DRY_RUN=true → no publica en redes (recomendado primeras rondas)
DRY_RUN=true

# Hora de producción del batch diario (24h)
PRODUCE_HOUR=22

# Whisper: "tiny" (rápido), "base" (default), "small" (mejor calidad)
WHISPER_MODEL=base

# Path del binario rvc-cli si no está en PATH
# RVC_CLI_BIN=rvc-cli

# Directorio de modelos RVC (.pth / .index)
MODELS_DIR=models

# ==========================================
# 🤖 CUENTA 1: REPO-PETER (GitHub)
# ==========================================
REPO_PETER_SESSION_DIR=./sessions/repo_peter
REPO_PETER_IG_USER=
REPO_PETER_IG_PASS=
REPO_PETER_TT_USER=
REPO_PETER_TT_PASS=
REPO_PETER_YT_USER=
REPO_PETER_YT_PASS=

# ==========================================
# 🤖 CUENTA 2: DEV-PETER (Noticias IA)
# ==========================================
DEV_PETER_SESSION_DIR=./sessions/dev_peter
DEV_PETER_IG_USER=
DEV_PETER_IG_PASS=
DEV_PETER_TT_USER=
DEV_PETER_TT_PASS=
DEV_PETER_YT_USER=
DEV_PETER_YT_PASS=

# ==========================================
# 🎙️ Modelos de voz (HuggingFace)
# ==========================================
MODEL_PETER_PTH=https://huggingface.co/binant/Peter_Griffin__Family_Guy___RVC_V2__300_Epoch/resolve/main/model.pth
MODEL_PETER_INDEX=https://huggingface.co/binant/Peter_Griffin__Family_Guy___RVC_V2__300_Epoch/resolve/main/model.index
MODEL_STEWIE_PTH=https://huggingface.co/Bigzz99/Stewie_Griffin_Family_Guy/resolve/main/added_IVF425_Flat_nprobe_1_Stewie_v2.zip
MODEL_STEWIE_INDEX=https://huggingface.co/Bigzz99/Stewie_Griffin_Family_Guy/resolve/main/added_IVF425_Flat_nprobe_1_Stewie_v2.index
